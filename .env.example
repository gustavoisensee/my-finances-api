# Database Configuration
# ======================
# Get these from your Supabase project dashboard
# Settings → Database → Connection String

# Pooled connection (for application runtime)
# Uses port 6543 with PgBouncer for connection pooling
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (required for migrations)
# Uses port 5432 for direct database access
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Server Configuration
# ====================
# Port where the API server will run
NODE_PORT=3001

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace [PROJECT-REF], [PASSWORD], and [REGION] with your Supabase credentials
# 3. Never commit the .env file to version control

# Firebase Admin — verify Firebase ID tokens from the SPA (Authorization: Bearer)
# Firebase Console → Project settings → Service accounts → Generate new private key
#
# Option A (recommended for managed platforms like AWS App Runner):
#   Set these three individual env vars from the service account JSON:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Option B: paste the full service account JSON on one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Option C: point to a local file (less suitable for managed platforms):
# GOOGLE_APPLICATION_CREDENTIALS=./firebase/secrets.json

# Optional: comma-separated Firebase Auth UIDs that may call admin routes (without custom claims)
# ADMIN_FIREBASE_UIDS=uid1,uid2
